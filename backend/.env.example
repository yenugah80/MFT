# ============================================
# MyFoodTracker - Environment Variables
# ============================================
# IMPORTANT: This is a template file. Copy to .env and fill in real values.
# NEVER commit .env file to git!

# --------------------------------------------
# Database Configuration
# --------------------------------------------
DATABASE_URL=postgresql://username:password@localhost:5432/myfoodtracker

# --------------------------------------------
# Server Configuration
# --------------------------------------------
PORT=5001
NODE_ENV=development

# --------------------------------------------
# Authentication (Clerk)
# --------------------------------------------
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx

# --------------------------------------------
# External APIs - CRITICAL: Keep these secret!
# --------------------------------------------

# USDA FoodData Central API
# Get your key: https://fdc.nal.usda.gov/api-key-signup.html
# Rate Limits: 1,000 requests/hour (free tier)
USDA_API_KEY=DEMO_KEY

# OpenAI API
# Get your key: https://platform.openai.com/api-keys
# Cost: ~$0.002 per 1K tokens (GPT-4o-mini)
OPENAI_API_KEY=sk-proj-xxxxx

# --------------------------------------------
# API Configuration & Limits
# --------------------------------------------

# USDA API Settings
USDA_RATE_LIMIT_PER_HOUR=900
USDA_CACHE_TTL_SECONDS=86400
USDA_TIMEOUT_MS=10000

# OpenAI API Settings
OPENAI_RATE_LIMIT_PER_MINUTE=60
OPENAI_MAX_TOKENS=1000
OPENAI_TIMEOUT_MS=30000
OPENAI_MODEL=gpt-4o-mini

# OpenFoodFacts (No key required, but configurable)
OFF_TIMEOUT_MS=10000
OFF_CACHE_TTL_SECONDS=604800

# --------------------------------------------
# Redis Cache (Optional - for production)
# --------------------------------------------
REDIS_URL=redis://localhost:6379
ENABLE_REDIS_CACHE=false

# --------------------------------------------
# Monitoring & Observability (Optional)
# --------------------------------------------
SENTRY_DSN=
LOG_LEVEL=info

# --------------------------------------------
# Security
# --------------------------------------------
API_REQUEST_TIMEOUT_MS=30000
MAX_REQUESTS_PER_USER_PER_HOUR=100
ENABLE_API_METRICS=true
