# MyFoodTracker Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Database
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require

# API Keys (Get from respective services)
OPENAI_API_KEY=sk-proj-your-openai-key-here
USDA_API_KEY=your-usda-key-here

# Authentication
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key-here

# Security
HEALTH_TOKEN=generate-strong-random-token-here

# Server Configuration
PORT=5001
NODE_ENV=development

# OpenAI Configuration
OPENAI_TIMEOUT_MS=30000
OPENAI_RATE_LIMIT_PER_MINUTE=60
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1000
OPENAI_VISION_MODEL=gpt-4o

# Feature Flags
# USDA verification (disabled by default - validating OpenAI-only accuracy first)
# Set to 'true' to enable USDA verification for low-confidence foods
ENABLE_USDA_VERIFICATION=false

# Logging
LOG_LEVEL=info

# Cloudflare (Production)
# Set to 'true' to require requests come through Cloudflare
REQUIRE_CLOUDFLARE=false

# Redis (Optional - for distributed caching and rate limiting)
# If not set, falls back to in-memory caching (suitable for single-instance deployments)
# REDIS_URL=redis://username:password@host:port

# Admin Users (Required for admin endpoints)
# Comma-separated list of Clerk user IDs with admin access
# Get your user ID from Clerk Dashboard > Users > select user > copy "User ID"
# ADMIN_USER_IDS=user_abc123,user_def456

# Firebase Cloud Messaging (FCM) - For server-triggered push notifications
# Option 1: JSON string of service account (recommended for production)
# Get from Firebase Console > Project Settings > Service accounts > Generate new private key
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Option 2: Path to service account JSON file (for local development)
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Cloudflare Turnstile (Human Verification)
# Get keys from Cloudflare Dashboard > Turnstile > Add Site
# TURNSTILE_SITE_KEY=0x4AAAAAAXXXXXX
# TURNSTILE_SECRET_KEY=0x4AAAAAAXXXXXX

# Debug Key (for /api/debug/* endpoints in production)
# DEBUG_KEY=your-secret-debug-key
