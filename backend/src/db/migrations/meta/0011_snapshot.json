        },
        "nutriscore_check": {
          "name": "nutriscore_check",
          "value": "\"food_log\".\"nutriscore\" IS NULL OR \"food_log\".\"nutriscore\" IN ('A', 'B', 'C', 'D', 'E')"
        },
        "ecoscore_check": {
          "name": "ecoscore_check",
