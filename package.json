{
  "name": "mft",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "mobile",
    "backend",
    "worker",
    "shared"
  ],
  "scripts": {
    "postinstall": "patch-package",
    "dev": "npm run dev:backend",
    "dev:backend": "npm --prefix backend run dev",
    "dev:mobile": "npm --prefix mobile start -- --clear",
    "dev:worker": "npm --prefix worker run dev",
    "build:mobile:android": "npm --prefix mobile run android",
    "build:mobile:ios": "npm --prefix mobile run ios",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "react-native-worklets": "0.8.3"
  }
}
