{
  "expo": {
    "name": "MFT : My Food & Mood Tracker",
    "slug": "my-food-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/styles/images/icon.png",
    "scheme": "my-food-tracker",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zennxt.myfoodtracker",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "NSCameraUsageDescription": "MFT needs camera access to photograph your meals for nutrition analysis.",
        "NSMicrophoneUsageDescription": "MFT needs microphone access for voice meal logging.",
        "NSPhotoLibraryUsageDescription": "MFT needs photo library access to select food photos for analysis.",
        "NSPhotoLibraryAddUsageDescription": "MFT needs permission to save meal photos to your library.",
        "CFBundleAllowMixedLocalizations": true,
        "ITSAppUsesNonExemptEncryption": false,
        "NSSpeechRecognitionUsageDescription": "MFT uses speech recognition to transcribe your voice meal logs.",
        "NSHealthShareUsageDescription": "MFT reads your step count and activity data to give you personalized nutrition recommendations.",
        "NSHealthUpdateUsageDescription": "MFT writes your logged meals and hydration to Apple Health to keep your health data in sync."
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": [
              "C617.1"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/styles/images/adaptive-icon.png",
        "backgroundImage": "./assets/styles/images/adaptive-icon.png",
        "monochromeImage": "./assets/styles/images/adaptive-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.zennxt.myfoodtracker",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_DISTANCE",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_WEIGHT",
        "android.permission.health.WRITE_NUTRITION",
        "android.permission.health.WRITE_HYDRATION"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/styles/images/adaptive-icon.png"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      "./plugins/withFirebaseModularHeaders.js",
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "MFT needs camera access to photograph your meals for nutrition analysis.",
          "microphonePermission": "MFT needs microphone access for voice meal logging."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "MFT needs microphone access for voice meal logging."
        }
      ],
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "Allow MFT to access your microphone for voice logging.",
          "speechRecognitionPermission": "Allow MFT to transcribe your speech for food logging."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MFT needs photo library access to select food photos for analysis.",
          "cameraPermission": "MFT needs camera access to photograph your meals."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/styles/images/adaptive-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#1F2937"
          }
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/styles/images/icon.png",
          "color": "#6B4EFF",
          "sounds": [],
          "mode": "production"
        }
      ],
      "./plugins/withAndroidManifestMergerFixes.js",
      "./plugins/withExcludeLegacySupportLibrary.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "apiUrl": "https://api.my-food-tracker.com/api",
      "router": {},
      "eas": {
        "projectId": "91264355-29bc-4019-be18-08002c3180c2"
      }
    },
    "owner": "harikay",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/91264355-29bc-4019-be18-08002c3180c2"
    }
  }
}
