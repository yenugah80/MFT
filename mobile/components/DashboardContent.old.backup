/**
 * PREMIUM DASHBOARD - Completely Refactored
 *
 * Design Philosophy: Focus on ONE hero metric (Calorie Ring)
 * Components: 7 max (Header, Ring, Stats, Macros, Chart, Meals, More)
 * Scroll Height: ~1180px (vs 2800px original)
 *
 * This is the TRUE premium implementation matching reference designs
 */

import React, { useState, useMemo, useCallback, useEffect, useRef } from "react";
import {
  View,
  ScrollView,
  StyleSheet,
  RefreshControl,
  Animated,
} from "react-native";
import { LinearGradient } from "expo-linear-gradient";
import { useRouter } from "expo-router";
import { useUser } from "@clerk/clerk-expo";
import * as Haptics from "expo-haptics";
import { trackEvent } from "../services/analytics";

// Core Hooks
import { useDashboard } from "../hooks/useDashboard";
import { useMoodTrends } from "../hooks/useMoodTrends";
import { useWaterLog } from "../hooks/useWaterLog";
import { useFoodLog } from "../hooks/useFoodLog";
import { useNotification } from "../providers/NotificationProvider";
import { useProfileContext } from "../providers/ProfileProvider";

// Premium Insights (Optional)
import {
  usePredictiveInsights,
  useWhatToChange,
} from "../hooks/useInsights";

// Subscription context
import { useSubscription, TIERS } from "../contexts/SubscriptionContext";

// NEW DESIGN SYSTEM
import {
  COLORS,
  TYPOGRAPHY,
  SPACING,
  RADIUS,
  SHADOWS,
  ANIMATION,
} from "../constants/designSystem";

// NEW PREMIUM COMPONENTS (Only 7)
import PremiumHeader from "./dashboard/PremiumHeader";
import DailyCalorieRing from "./dashboard/DailyCalorieRing";
import QuickStatsRow from "./dashboard/QuickStatsRow";
import MacroBreakdownSection from "./dashboard/MacroBreakdownSection";
import WeeklyProgressChart from "./dashboard/WeeklyProgressChart";
import MealTabsSection from "./dashboard/MealTabsSection";
import CollapsibleMoreInsights from "./dashboard/CollapsibleMoreInsights";

// Loading & Error
import DashboardSkeleton from "./dashboard/DashboardSkeleton";
import EmptyState from "./EmptyState";
import FadeInView from "./FadeInView";

// Utilities
import {
  parseLiters,
  parseGoal,
  parseCalories,
  parseMacro,
  calculatePercentage,
} from "../utils/safeNumbers";

// ============================================================================
// HELPER FUNCTIONS
// ============================================================================

function dedupeLogs(logs) {
  const seen = new Set();
  return logs.filter(log => {
    const key = log.clientEventId || log.id;
    if (!key) return true;
    if (seen.has(key)) return false;
    seen.add(key);
    return true;
  });
}

// ============================================================================
// MAIN PREMIUM DASHBOARD COMPONENT
// ============================================================================

export default function DashboardContentPremium() {
  const { data, isLoading, error, refetch } = useDashboard();
  const { logs: localFoodLogs } = useFoodLog();
  const { profile: contextProfile } = useProfileContext();
  const notify = useNotification();
  const router = useRouter();
  const { user } = useUser();

  // Subscription state
  const subscription = useSubscription();
  const isPremium = subscription?.isPremium ?? false;

  // Mood trends
  const { data: trendData } = useMoodTrends({ period: "week" });

  // Water logging
  const { logWater } = useWaterLog();

  // Premium features
  const { energyPrediction } = usePredictiveInsights({ enabled: isPremium });
  const { title: whatToChangeTitle } = useWhatToChange({ enabled: isPremium });

  // Refresh control
  const [refreshing, setRefreshing] = useState(false);
  const headerOpacity = useRef(new Animated.Value(0)).current;

  useEffect(() => {
    Animated.timing(headerOpacity, {
      toValue: 1,
      duration: ANIMATION.duration.normal,
      useNativeDriver: true,
    }).start();
  }, []);

  const onRefresh = useCallback(async () => {
    setRefreshing(true);
    await Haptics.impactAsync(Haptics.ImpactFeedbackStyle.Light);
    try {
      await refetch();
    } finally {
      setRefreshing(false);
    }
  }, [refetch]);

  // Deduplicate food logs
  const uniqueFoodLogs = useMemo(() => {
    const todayStart = new Date();
    todayStart.setHours(0, 0, 0, 0);
    const todayEnd = new Date();
    todayEnd.setHours(23, 59, 59, 999);

    const todayLocalLogs = localFoodLogs.filter(log => {
      const logDate = new Date(log.timestamp || log.loggedDate);
      return logDate >= todayStart && logDate <= todayEnd;
    });

    const backendLogs = data?.today?.foodLogs || [];
    return dedupeLogs([...backendLogs, ...todayLocalLogs]);
  }, [data, localFoodLogs]);

  // Calculate metrics
  const metrics = useMemo(() => {
    const totalCalories = uniqueFoodLogs.reduce(
      (sum, log) => sum + parseCalories(log.calories),
      0
    );
    const calorieGoal = parseGoal(data?.goals?.dailyCalories, 2000, 800, 10000);

    const totalProtein = uniqueFoodLogs.reduce(
      (sum, log) => sum + parseMacro(log.protein),
      0
    );
    const totalCarbs = uniqueFoodLogs.reduce(
      (sum, log) => sum + parseMacro(log.carbs),
      0
    );
    const totalFats = uniqueFoodLogs.reduce(
      (sum, log) => sum + parseMacro(log.fats || log.fat),
      0
    );

    const waterIntake = parseLiters(data?.today?.waterIntakeLiters);
    const waterGoal = parseGoal(data?.goals?.waterLiters, 2.0, 0.5, 10);

    const streak = data?.gamification?.streak || 0;

    return {
      totalCalories,
      calorieGoal,
      waterIntake,
      waterGoal,
      mealsLogged: uniqueFoodLogs.length,
      macros: {
        protein: totalProtein,
        carbs: totalCarbs,
        fat: totalFats,
      },
      streak,
    };
  }, [data, uniqueFoodLogs]);

  // Navigation handlers
  const handleSettingsPress = useCallback(() => {
    router.push("/profile/settings");
  }, [router]);

  const handleAddMeal = useCallback(() => {
    trackEvent("dashboard_add_meal");
    router.push("/(tabs)/log");
  }, [router]);

  const handleMealPress = useCallback((meal) => {
    trackEvent("dashboard_meal_tap");
    router.push({
      pathname: "/(tabs)/log",
      params: { mealId: meal.id },
    });
  }, [router]);

  const handleMoodPress = useCallback(() => {
    trackEvent("dashboard_mood_tap");
    router.push("/insights/mood");
  }, [router]);

  const handleEnergyPress = useCallback(() => {
    trackEvent("dashboard_energy_tap");
    router.push("/insights/energy");
  }, [router]);

  const handleProgressPress = useCallback(() => {
    trackEvent("dashboard_progress_tap");
    router.push("/profile");
  }, [router]);

  const handleRecommendationPress = useCallback((rec) => {
    trackEvent("dashboard_recommendation_tap", { id: rec.id });
    router.push("/insights/recommendations");
  }, [router]);

  // Loading state
  if (isLoading && !data) {
    return <DashboardSkeleton />;
  }

  // Error state
  if (error && !data) {
    return (
      <EmptyState
        icon="cloud-offline-outline"
        title="Unable to Load"
        message="Please check your connection and try again."
        actionLabel="Retry"
        onAction={refetch}
      />
    );
  }

  const userName = user?.firstName || contextProfile?.name || "";

  return (
    <LinearGradient
      colors={["#1A1A1A", "#2D2D2D"]}
      style={styles.container}
    >
      <ScrollView
        style={styles.scrollView}
        contentContainerStyle={styles.content}
        showsVerticalScrollIndicator={false}
        refreshControl={
          <RefreshControl
            refreshing={refreshing}
            onRefresh={onRefresh}
            tintColor={COLORS.nutrition.primary}
          />
        }
      >
        {/* 1. PREMIUM HEADER */}
        <Animated.View style={{ opacity: headerOpacity }}>
          <FadeInView animation="fadeIn" delay={0}>
            <PremiumHeader
              userName={userName}
              onSettingsPress={handleSettingsPress}
            />
          </FadeInView>
        </Animated.View>

        {/* 2. HERO CALORIE RING (50% of screen, dominates) */}
        <FadeInView animation="floatIn" delay={100}>
          <DailyCalorieRing
            consumed={metrics.totalCalories}
            goal={metrics.calorieGoal}
            burned={data?.today?.caloriesBurned || 120}
            showDetails={true}
          />
        </FadeInView>

        {/* 3. QUICK STATS ROW */}
        <FadeInView animation="floatIn" delay={200}>
          <QuickStatsRow
            target={metrics.calorieGoal}
            consumed={metrics.totalCalories}
            burned={data?.today?.caloriesBurned || 120}
          />
        </FadeInView>

        {/* 4. MACRO BREAKDOWN */}
        <FadeInView animation="floatIn" delay={300}>
          <MacroBreakdownSection
            protein={metrics.macros.protein}
            carbs={metrics.macros.carbs}
            fat={metrics.macros.fat}
            proteinGoal={data?.goals?.proteinG || 100}
            carbsGoal={data?.goals?.carbsG || 250}
            fatGoal={data?.goals?.fatG || 65}
          />
        </FadeInView>

        {/* 5. WEEKLY PROGRESS CHART */}
        <FadeInView animation="floatIn" delay={400}>
          <WeeklyProgressChart
            weekData={data?.weeklyData || [
              { day: 0, calories: 1800 },
              { day: 1, calories: 2100 },
              { day: 2, calories: 1600 },
              { day: 3, calories: 2300 },
              { day: 4, calories: 1900 },
              { day: 5, calories: 2000 },
              { day: 6, calories: metrics.totalCalories },
            ]}
            goal={metrics.calorieGoal}
          />
        </FadeInView>

        {/* 6. TODAY'S MEALS */}
        <FadeInView animation="floatIn" delay={500}>
          <MealTabsSection
            meals={uniqueFoodLogs.map(log => ({
              id: log.id,
              type: log.mealType || "lunch", // breakfast, lunch, dinner
              name: log.foodName || "Unknown",
              time: log.loggedDate
                ? new Date(log.loggedDate).toLocaleTimeString("en-US", {
                    hour: "2-digit",
                    minute: "2-digit",
                  })
                : "N/A",
              calories: parseCalories(log.calories),
              image: log.imageUrl,
            }))}
            onAddMeal={handleAddMeal}
            onMealPress={handleMealPress}
          />
        </FadeInView>

        {/* 7. MORE INSIGHTS (Collapsible) */}
        <FadeInView animation="floatIn" delay={600}>
          <CollapsibleMoreInsights
            moodScore={trendData?.moodScores?.[6] || 7.2}
            moodTrend={trendData?.moodTrend || "up"}
            energyStatement={energyPrediction?.statement || "Analyzing..."}
            energyPremium={isPremium}
            streak={metrics.streak}
            nextMilestone={7}
            recommendations={
              whatToChangeTitle
                ? [
                    {
                      id: 1,
                      title: whatToChangeTitle,
                      icon: "💡",
                    },
                  ]
                : []
            }
            onMoodPress={handleMoodPress}
            onEnergyPress={handleEnergyPress}
            onProgressPress={handleProgressPress}
            onRecommendationPress={handleRecommendationPress}
          />
        </FadeInView>

        {/* Bottom Padding */}
        <View style={styles.bottomPadding} />
      </ScrollView>
    </LinearGradient>
  );
}

// ============================================================================
// STYLES
// ============================================================================

const styles = StyleSheet.create({
  container: {
    flex: 1,
  },
  scrollView: {
    flex: 1,
  },
  content: {
    paddingBottom: SPACING["5xl"],
  },
  bottomPadding: {
    height: SPACING["3xl"],
  },
});
