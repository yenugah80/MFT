const { width: SCREEN_WIDTH } = Dimensions.get('window');
const CARD_GAP = SPACING[3];
const CARD_WIDTH = (SCREEN_WIDTH - SPACING[5] * 2 - CARD_GAP) / 2;

// ============================================================================
// HELPER FUNCTIONS
// ============================================================================

function dedupeLogs(logs) {
  const seen = new Set();
  return logs.filter(log => {
    const key = log.clientEventId || log.id;
    if (!key) return true;
    if (seen.has(key)) return false;
    seen.add(key);
    return true;
  });
}

function getMoodLabel(log) {
  return log?.mood || log?.moodLabel || null;
}

function getEnergyLevel(log) {
  const energy = Number(log?.energy ?? log?.energyLevel);
  return Number.isFinite(energy) ? energy : null;
}

function calculateFoodQuality(foodLogs) {
  if (!foodLogs?.length) {
    return { wholeFoodPercent: 50, nutrientDensity: 50, balance: 50, nutrientGaps: [] };
  }

  let wholeFoodCount = 0;
  let processedCount = 0;
  let totalProtein = 0;
  let totalCarbs = 0;
  let totalFats = 0;
  let totalCalories = 0;

  foodLogs.forEach(log => {
    const name = (log.foodName || '').toLowerCase();
    const isWholeFood = /chicken|fish|egg|vegetable|fruit|rice|beans|oats|salmon|beef|apple|banana|spinach|broccoli/.test(name);
    const isProcessed = /pizza|burger|fries|chips|candy|soda|cookie|cake|processed|instant/.test(name);

    if (isWholeFood) wholeFoodCount++;
    else if (isProcessed) processedCount++;
    else wholeFoodCount += 0.5;

    totalProtein += parseMacro(log.protein);
    totalCarbs += parseMacro(log.carbs);
    totalFats += parseMacro(log.fats || log.fat);
    totalCalories += parseCalories(log.calories);
  });

  const total = foodLogs.length;
  const wholeFoodPercent = Math.round((wholeFoodCount / total) * 100);
  const proteinPer100Cal = totalCalories > 0 ? (totalProtein / totalCalories) * 100 : 0;
  const nutrientDensity = Math.min(Math.round(proteinPer100Cal * 4), 100);

  const totalMacros = totalProtein + totalCarbs + totalFats;
  if (totalMacros === 0) return { wholeFoodPercent: 50, nutrientDensity: 50, balance: 50, nutrientGaps: [] };

  const proteinRatio = totalProtein / totalMacros;
  const carbRatio = totalCarbs / totalMacros;
  const fatRatio = totalFats / totalMacros;

  const proteinDev = Math.abs(proteinRatio - 0.30);
  const carbDev = Math.abs(carbRatio - 0.40);
  const fatDev = Math.abs(fatRatio - 0.30);
  const balance = Math.round(100 - (proteinDev + carbDev + fatDev) * 100);

  const nutrientGaps = [];
  if (proteinRatio < 0.20) nutrientGaps.push('Protein');
  if (totalCalories > 0 && totalCalories < 1200) nutrientGaps.push('Fiber');

  return { wholeFoodPercent, nutrientDensity, balance, nutrientGaps };
}

function getCalorieSource(foodLogs) {
  if (!foodLogs?.length) return 'aiText';

  const sources = foodLogs.map(log => {
    if (log.barcode) return 'barcode';
    if (log.imageUrl) return 'aiPhoto';
    if (log.fromDatabase) return 'database';
    return 'aiText';
  });

  const priority = ['barcode', 'database', 'aiText', 'aiPhoto', 'mixedDish'];
  return sources.reduce((least, curr) => {
    return priority.indexOf(curr) > priority.indexOf(least) ? curr : least;
  }, 'barcode');
}

// Note: Mock data removed - now using real API via useInsights hooks

// Nutri-Score calculation helper
function calculateNutriScoreGrade(data) {
  if (!data || !data.today) {
    return { grade: 'N/A', score: 0, colorScore: '#999999' };
  }

  const foodLogs = data.today.foodLogs || [];
  if (foodLogs.length === 0) {
    return { grade: 'N/A', score: 0, colorScore: '#999999' };
  }

  let totalScore = 0;
  let count = 0;

  foodLogs.forEach(log => {
    const name = (log.foodName || '').toLowerCase();
    const isHealthy = /vegetable|fruit|salad|lean|chicken|fish|egg|bean|lentil|whole grain|oat|nut|yogurt|tofu/.test(name);
    const isUnhealthy = /pizza|burger|fries|chips|candy|soda|cookie|cake|processed|fried|fast food/.test(name);

    if (isUnhealthy) {
      totalScore += 30;
    } else if (isHealthy) {
      totalScore += 85;
    } else {
      totalScore += 60;
    }
    count++;
  });

  const average = Math.round(totalScore / count);
  let grade = 'C';
  let colorScore = '#FDB913';

  if (average >= 80) {
    grade = 'A';
    colorScore = '#27AE60';
  } else if (average >= 60) {
    grade = 'B';
    colorScore = '#52C41A';
  } else if (average >= 40) {
    grade = 'C';
    colorScore = '#FDB913';
  } else if (average >= 20) {
    grade = 'D';
    colorScore = '#FF7A45';
  } else {
    grade = 'E';
    colorScore = '#E74C3C';
  }

  return { grade, score: average, colorScore };
}

// Payment system flag - set to true once RevenueCat/payment gateway is wired
const PAYMENT_SYSTEM_READY = false;

// ============================================================================
// PREMIUM UPGRADE PROMPT COMPONENT
// ============================================================================

function PremiumUpgradeCard({ feature, onUpgrade, style }) {
  const { scale, onPressIn, onPressOut } = usePressAnimation();

  return (
    <Animated.View style={[{ transform: [{ scale }] }, style]}>
      <TouchableOpacity
        onPress={onUpgrade}
        onPressIn={onPressIn}
        onPressOut={onPressOut}
        activeOpacity={0.9}
      >
        <LinearGradient
          colors={PREMIUM_COLORS.functional.insights.gradient}
          start={{ x: 0, y: 0 }}
          end={{ x: 1, y: 1 }}
          style={styles.upgradeCard}
        >
          <View style={styles.upgradeIcon}>
            <Ionicons name="diamond" size={24} color="#FFFFFF" />
          </View>
          <View style={styles.upgradeContent}>
            <Text style={styles.upgradeTitle}>Unlock {feature}</Text>
            <Text style={styles.upgradeSubtitle}>
              Get personalized 5W2H recommendations
            </Text>
          </View>
          <Ionicons name="chevron-forward" size={20} color="rgba(255,255,255,0.8)" />
        </LinearGradient>
      </TouchableOpacity>
    </Animated.View>
  );
}

// ============================================================================
// MAIN DASHBOARD COMPONENT
// ============================================================================

export default function DashboardContent() {
  const { data, isLoading, error, refetch } = useDashboard();
  const { logs: localFoodLogs } = useFoodLog();
  const { profile: contextProfile } = useProfileContext();
  const [refreshing, setRefreshing] = useState(false);
  const notify = useNotification();
  const router = useRouter();
  const { user } = useUser();
  const hasTrackedView = useRef(false);

  // Subscription state for tier-aware rendering
  const subscription = useSubscription();
  const isPremium = subscription?.isPremium ?? false;
  const isBasic = subscription?.isBasic ?? false;
  const currentTier = subscription?.tier ?? TIERS.FREE;

  // Mood tracking
  const { data: trendData } = useMoodTrends({ period: 'week' });

  // Water tracking
  const { logWater } = useWaterLog();

  // Premium Intelligence Data (only fetch for premium users)
  const {
    energyPrediction,
    nutrientPrediction,
    dataPoints: predictiveDataPoints,
  } = usePredictiveInsights({ enabled: isPremium });

  const {
    correlations,
    hasCorrelations,
  } = useCorrelations({ enabled: isPremium, limit: 5 });

  const {
    weekRange,
    dateLabel,
    narrative,
    highlights,
    metrics: weeklyMetrics,
    focusAreas,
    hasData: hasWeeklyNarrative,
  } = useWeeklyNarrative({ enabled: isPremium });

  const {
    title: whatToChangeTitle,
    subtitle: whatToChangeSubtitle,
    whyMatters,
    difficulty,
    impact,
    timeRequired,
    schedule,
    alternatives,
    confidence: whatToChangeConfidence,
    dataPoints: whatToChangeDataPoints,
    hasData: hasWhatToChange,
  } = useWhatToChange({ enabled: isPremium });

  // Outcome Tracking (Real Data - Premium)
  const {
    effectivenessRate,
    totalRecommendations,
    hasData: hasOutcomeData,
  } = useOutcomeStats({ enabled: isPremium });

  // Wellness Confidence (Real Data - Everyone)
  const {
    confidence: wellnessConfidence,
  } = useWellnessConfidence({ enabled: true });

  // Animation values
  const headerOpacity = useRef(new Animated.Value(0)).current;
  const heroScale = useRef(new Animated.Value(0.95)).current;

  // Entrance animations
  useEffect(() => {
    Animated.parallel([
      Animated.timing(headerOpacity, {
        toValue: 1,
        duration: ANIMATION.duration.normal,
        useNativeDriver: true,
      }),
      Animated.spring(heroScale, {
        toValue: 1,
        ...SPRING.smooth,
      }),
    ]).start();
  }, []);

  // Track dashboard view
  useEffect(() => {
    if (!hasTrackedView.current && data) {
      const mealsCount = data?.today?.foodLogs?.length || 0;
      const moodsCount = data?.today?.moodLogs?.length || 0;
      const waterLiters = parseLiters(data?.today?.waterIntakeLiters);

      trackEvent('dashboard_viewed', {
        has_meals: mealsCount > 0,
        has_mood: moodsCount > 0,
        water_intake_liters: waterLiters,
        subscription_tier: currentTier,
      });
      hasTrackedView.current = true;
    }
  }, [data, currentTier]);

  const onRefresh = useCallback(async () => {
    setRefreshing(true);
    await Haptics.impactAsync(Haptics.ImpactFeedbackStyle.Light);
    try {
      await refetch();
    } finally {
      setRefreshing(false);
    }
  }, [refetch]);

  // Deduplicate food logs
  const uniqueFoodLogs = useMemo(() => {
    const todayStart = new Date();
    todayStart.setHours(0, 0, 0, 0);
    const todayEnd = new Date();
    todayEnd.setHours(23, 59, 59, 999);

    const todayLocalLogs = localFoodLogs.filter(log => {
      const logDate = new Date(log.timestamp || log.loggedDate);
      return logDate >= todayStart && logDate <= todayEnd;
    });

    const backendLogs = data?.today?.foodLogs || [];
    return dedupeLogs([...backendLogs, ...todayLocalLogs]);
  }, [data, localFoodLogs]);

  // Calculate metrics
  const metrics = useMemo(() => {
    const moodLogs = data?.today?.moodLogs || [];
    const latestMood = moodLogs[0];

    const waterIntake = parseLiters(data?.today?.waterIntakeLiters);
    const waterGoal = parseGoal(data?.goals?.waterLiters, 2.0, 0.5, 10);
    const waterProgress = calculatePercentage(waterIntake, waterGoal, 200);

    const totalCalories = uniqueFoodLogs.reduce((sum, log) => sum + parseCalories(log.calories), 0);
    const calorieGoal = parseGoal(data?.goals?.dailyCalories, 2000, 800, 10000);

    const foodQuality = calculateFoodQuality(uniqueFoodLogs);
    const calorieSource = getCalorieSource(uniqueFoodLogs);

    const streak = data?.gamification?.streak || 0;

    // Wellness score calculation
    const nutritionScore = Math.min((totalCalories / calorieGoal) * 100, 100);
    const hydrationScore = waterProgress;
    const moodScore = latestMood ? (getEnergyLevel(latestMood) || 5) * 10 : 50;
    const consistencyScore = Math.min(streak * 10, 100);

    const overallWellness = Math.round(
      nutritionScore * 0.3 +
      hydrationScore * 0.25 +
      moodScore * 0.25 +
      consistencyScore * 0.2
    );

    // Macro breakdown
    const totalProtein = uniqueFoodLogs.reduce((sum, log) => sum + parseMacro(log.protein), 0);
    const totalCarbs = uniqueFoodLogs.reduce((sum, log) => sum + parseMacro(log.carbs), 0);
    const totalFats = uniqueFoodLogs.reduce((sum, log) => sum + parseMacro(log.fats || log.fat), 0);

    // Calculate Nutri-Score grade
    const nutriScore = calculateNutriScoreGrade(data);

    return {
      currentMood: getMoodLabel(latestMood),
      energyLevel: getEnergyLevel(latestMood),
      lastMoodCheckIn: latestMood?.loggedDate,
      moodLogged: moodLogs.length > 0,
      waterIntake,
      waterGoal,
      waterProgress,
      mealsLogged: uniqueFoodLogs.length,
      totalCalories,
      calorieGoal,
      calorieSource,
      foodQuality,
      overallWellness,
      nutritionScore,
      hydrationScore,
      moodScore,
      consistencyScore,
      streak,
      macros: {
        protein: totalProtein,
        carbs: totalCarbs,
        fat: totalFats,
        totalCalories,
      },
      nutriScore,
    };
  }, [data, uniqueFoodLogs]);

  // Navigation handlers
  const handleMoodPress = useCallback(() => {
    trackEvent('dashboard_mood_tap');
    router.push({ pathname: '/(tabs)/log', params: { focus: 'mood' } });
  }, [router]);

  const handleFoodPress = useCallback(() => {
    trackEvent('dashboard_food_tap');
    router.push('/(tabs)/log');
  }, [router]);

  const handleWaterPress = useCallback(() => {
    trackEvent('dashboard_water_tap');
    router.push('/insights/hydration');
  }, [router]);

  const handleQuickAddWater = useCallback(async (amountLiters) => {
    try {
      await Haptics.impactAsync(Haptics.ImpactFeedbackStyle.Light);
      await logWater(amountLiters);
      notify.success(`Added ${Math.round(amountLiters * 1000)}ml`);
      refetch();
    } catch (err) {
      notify.error('Failed to log water');
    }
  }, [logWater, notify, refetch]);

  const handleActionPress = useCallback((actionType) => {
    trackEvent('dashboard_action_tap', { action: actionType });

    switch (actionType) {
      case 'logMeal':
        router.push('/(tabs)/log');
        break;
      case 'drinkWater':
        handleQuickAddWater(0.25);
        break;
      case 'checkMood':
        router.push({ pathname: '/(tabs)/log', params: { focus: 'mood' } });
        break;
      case 'celebrate':
      case 'takeBreak':
        notify.success('You\'re doing great!');
        break;
      default:
        router.push('/(tabs)/log');
    }
  }, [router, handleQuickAddWater, notify]);

  const handleSettingsPress = useCallback(() => {
    router.push('/profile/settings');
  }, [router]);

  const handleWellnessPress = useCallback(() => {
    trackEvent('dashboard_wellness_tap');
  }, []);

  const handleUpgradePress = useCallback(() => {
    trackEvent('dashboard_upgrade_tap');
    router.push('/profile/subscription');
  }, [router]);

  const handleOutcomeTrackingPress = useCallback(() => {
    trackEvent('dashboard_outcome_tracking_tap');
    router.push('/insights/outcomes');
  }, [router]);

  const handleRecommendationComplete = useCallback((rec) => {
    trackEvent('recommendation_completed', { id: rec.id });
    notify.success('Great job! Recommendation marked as complete.');
  }, [notify]);

  const handleRecommendationDismiss = useCallback((rec) => {
    trackEvent('recommendation_dismissed', { id: rec.id });
  }, []);

  // Loading state
  if (isLoading && !data) {
    return <DashboardSkeleton />;
  }

  // Error state
  if (error && !data) {
    return (
      <EmptyState
        icon="cloud-offline-outline"
        title="Unable to Load"
        message="Please check your connection and try again."
        actionLabel="Retry"
        onAction={refetch}
      />
    );
  }

  const userName = user?.firstName || contextProfile?.name || '';

  return (
    <LinearGradient
      colors={['#1A1A1A', '#2D2D2D']}
      style={styles.container}
    >
      <ScrollView
        style={styles.scrollView}
        contentContainerStyle={styles.content}
        showsVerticalScrollIndicator={false}
        refreshControl={
          <RefreshControl
            refreshing={refreshing}
            onRefresh={onRefresh}
            tintColor={COLORS.nutrition.primary}
          />
        }
      >
        {/* Animated Header */}
        <Animated.View style={{ opacity: headerOpacity }}>
          <MinimalDashboardHeader
            userName={userName}
            mealsLogged={metrics.mealsLogged}
            mealGoal={3}
            waterProgress={metrics.waterProgress}
            moodLogged={metrics.moodLogged}
            streak={metrics.streak}
            onSettingsPress={handleSettingsPress}
            onMealsPress={handleFoodPress}
            onWaterPress={handleWaterPress}
            onMoodPress={handleMoodPress}
          />
        </Animated.View>

        {/* NEW 8-ELEMENT DASHBOARD LAYOUT */}

        {/* 1. Hero Wellness Gauge */}
        <Animated.View style={[styles.heroCard, { transform: [{ scale: heroScale }] }]}>
          <FadeInView animation="floatIn" delay={0}>
            <UnifiedWellnessScore
              score={metrics.overallWellness}
              breakdown={{
                nutrition: metrics.nutritionScore,
                hydration: metrics.hydrationScore,
                mood: metrics.moodScore,
                habits: metrics.consistencyScore,
              }}
              confidence={wellnessConfidence}
              onPress={handleWellnessPress}
            />
          </FadeInView>
        </Animated.View>

        {/* 2. Energy Stability Gauge (Premium Only) */}
        {isPremium && energyPrediction && (
          <FadeInView animation="floatIn" delay={150}>
            <EnergyStabilityGauge
              statement={energyPrediction.statement || 'Analyzing your energy patterns...'}
              hourlyLevels={energyPrediction.hourlyLevels || Array(24).fill(50)}
              prevention={energyPrediction.prevention}
              confidence={energyPrediction.confidence || 0.75}
              onPress={() => {
                trackEvent('energy_gauge_tap');
                router.push('/insights/energy');
              }}
            />
          </FadeInView>
        )}

        {/* 3. Nutri-Score Bar (Compact) */}
        <FadeInView animation="floatIn" delay={isPremium && energyPrediction ? 200 : 150}>
          <NutriScoreDial
            score={metrics.nutriScore.score}
            grade={metrics.nutriScore.grade}
            colorScore={metrics.nutriScore.colorScore}
            mealsLogged={metrics.mealsLogged}
            calorieSource={metrics.calorieSource}
            onPress={handleFoodPress}
          />
        </FadeInView>

        {/* 4. Macro + Hydration Row (Premium visual, Basic+Free simpler) */}
        <FadeInView animation="floatIn" delay={isPremium && energyPrediction ? 250 : 200}>
          <CompactMacroHydrationRow
            macros={metrics.macros}
            hydration={{
              current: metrics.waterIntake,
              goal: metrics.waterGoal,
              progress: metrics.waterProgress,
            }}
            onMacroPress={handleFoodPress}
            onHydrationPress={handleWaterPress}
          />
        </FadeInView>

        {/* 5. Mood Sparkline + Priority Recommendation (2-Column) */}
        {isPremium ? (
          <FadeInView animation="floatIn" delay={isPremium && energyPrediction ? 300 : 250}>
            <View style={styles.twoColumnRow}>
              <View style={styles.twoColumnCard}>
                <MoodEnergySparkline
                  scores={trendData?.moodScores || [6, 7, 5, 8, 7, 6, 7]}
                  todayIndex={6}
                  average={metrics.energyLevel || 5}
                  trend={trendData?.moodTrend}
                  onPress={handleMoodPress}
                />
              </View>

              {hasWhatToChange && (
                <View style={styles.twoColumnCard}>
                  <PriorityRecommendationCard
                    title={whatToChangeTitle}
                    subtitle={whatToChangeSubtitle}
                    difficulty={difficulty}
                    impact={impact}
                    confidence={whatToChangeConfidence}
                    onPress={() => {
                      trackEvent('priority_recommendation_tap');
                      router.push('/insights/recommendations');
                    }}
                  />
                </View>
              )}
            </View>
          </FadeInView>
        ) : (
          <FadeInView animation="floatIn" delay={isPremium && energyPrediction ? 300 : 250}>
            <MoodEnergySparkline
              scores={trendData?.moodScores || [6, 7, 5, 8, 7, 6, 7]}
              todayIndex={6}
              average={metrics.energyLevel || 5}
              trend={trendData?.moodTrend}
              onPress={handleMoodPress}
            />
          </FadeInView>
        )}

        {/* 6. Weekly Insights (Collapsible) */}
        <FadeInView animation="floatIn" delay={isPremium && energyPrediction ? 350 : 300}>
          <View style={styles.collapsedSection}>
            {isPremium && hasWeeklyNarrative ? (
              <WeeklyNarrativeCard
                weekRange={weekRange}
                dateLabel={dateLabel}
                narrative={narrative}
                highlights={highlights}
                metrics={weeklyMetrics}
                focusAreas={focusAreas}
                onFullReport={() => {
                  trackEvent('weekly_report_tap');
                  router.push('/history');
                }}
                onShareProgress={() => {
                  trackEvent('weekly_narrative_share');
                  notify.success('Share feature coming soon!');
                }}
                style={{ marginBottom: 0 }}
              />
            ) : (
              <CollapsibleSection
                title="Weekly Insights"
                subtitle={isPremium ? "Keep logging to see your story" : "Your patterns this week"}
                icon="analytics-outline"
                iconColor={PREMIUM_COLORS.brand.primary}
                defaultExpanded={false}
              >
                <WeeklyStoryCard
                  title={isPremium ? "Your week is building up" : "Your week at a glance"}
                  subtitle={isPremium ? "Log more meals to unlock your weekly narrative" : "Keep logging to reveal patterns"}
                  actionLabel={isPremium ? "View history" : "View full story"}
                  onAction={() => {
                    trackEvent('weekly_story_action');
                    router.push('/history');
                  }}
                />
              </CollapsibleSection>
            )}
          </View>
        </FadeInView>

        {/* 7. Progress & Streaks (Collapsible) */}
        {metrics.streak > 0 && (
          <FadeInView animation="floatIn" delay={isPremium && energyPrediction ? 400 : 350}>
            <CollapsibleSection
              title="Progress"
              subtitle={`${metrics.streak} day streak`}
              icon="trophy-outline"
              iconColor={COLORS.progress[0]}
              defaultExpanded={false}
              badge={metrics.streak >= 7 ? '🔥' : undefined}
            >
              <ProgressMilestonesCard
                reflectionStreak={metrics.streak}
                insightsUnlocked={trendData?.patternsDiscovered || 0}
                milestoneText={`${Math.max(0, 7 - metrics.streak)} days to next milestone`}
                onViewProgress={() => {
                  trackEvent('progress_view');
                  router.push('/profile');
                }}
              />
            </CollapsibleSection>
          </FadeInView>
        )}

        {/* NEW PREMIUM REFERENCE DESIGN COMPONENTS */}

        {/* Daily Calorie Ring (Hero Metric) */}
        <FadeInView animation="floatIn" delay={450}>
          <DailyCalorieRing
            consumed={metrics.totalCalories}
            goal={metrics.calorieGoal}
            burned={data?.today?.caloriesBurned || 120}
            showDetails={true}
          />
        </FadeInView>

        {/* Macro Breakdown Section */}
        <FadeInView animation="floatIn" delay={500}>
          <MacroBreakdownSection
            protein={metrics.macros.protein}
            carbs={metrics.macros.carbs}
            fat={metrics.macros.fat}
            proteinGoal={data?.goals?.proteinG || 100}
            carbsGoal={data?.goals?.carbsG || 250}
            fatGoal={data?.goals?.fatG || 65}
          />
        </FadeInView>

        {/* Weekly Progress Chart */}
        <FadeInView animation="floatIn" delay={550}>
          <WeeklyProgressChart
            weekData={data?.weeklyData || [
              { day: 0, calories: 1800 },
              { day: 1, calories: 2100 },
              { day: 2, calories: 1600 },
              { day: 3, calories: 2300 },
              { day: 4, calories: 1900 },
              { day: 5, calories: 2000 },
              { day: 6, calories: metrics.totalCalories },
            ]}
            goal={metrics.calorieGoal}
          />
        </FadeInView>

        {/* Bottom Padding */}
        <View style={styles.bottomPadding} />
      </ScrollView>
    </LinearGradient>
  );
}

// ============================================================================
// STYLES
// ============================================================================

const styles = StyleSheet.create({
  container: {
    flex: 1,
  },
  scrollView: {
    flex: 1,
  },
  content: {
    paddingHorizontal: SPACING[5],
  },

  // Hero Card
  heroCard: {
    marginBottom: SPACING[4],
  },

  // Two-Column Row (Mood + Recommendation)
  twoColumnRow: {
    flexDirection: 'row',
    gap: SPACING[3],
    marginBottom: SPACING[4],
  },
  twoColumnCard: {
    flex: 1,
  },

  // Collapsed Section
  collapsedSection: {
    marginBottom: SPACING[4],
  },


  // Bottom Padding
  bottomPadding: {
    height: SPACING[10],
  },
});
