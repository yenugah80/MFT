# MyFoodTracker Mobile - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git - it contains sensitive keys!

# ============================================================================
# Clerk Authentication
# ============================================================================
# Development Clerk key (get from https://clerk.com dashboard)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_dev_clerk_key_here

# Production Clerk key (optional - only if different from dev)
# EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY_PROD=pk_live_your_prod_clerk_key_here

# ============================================================================
# API Configuration
# ============================================================================
# Backend API URL
# For LOCAL development:
#   - iOS Simulator: http://localhost:5001/api
#   - Android Emulator: http://10.0.2.2:5001/api
#   - Physical Device: http://<your-local-ip>:5001/api
# For PRODUCTION: Leave commented out (app will use production URL automatically)

# Development (localhost backend)
EXPO_PUBLIC_API_URL=http://localhost:5001/api

# Staging (optional)
# EXPO_PUBLIC_API_URL=https://staging.myfoodtracker.com/api

# Production (automatic in production builds - no need to set)
# EXPO_PUBLIC_API_URL=https://myfoodtracker.onrender.com/api

# ============================================================================
# OpenAI API (Optional - for AI-powered food analysis)
# ============================================================================
# Get your API key from https://platform.openai.com/api-keys
# Only needed if you want to use AI features for food analysis
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# ============================================================================
# Notes
# ============================================================================
# - The app automatically uses production URLs when built for production
# - You only need to configure .env for local development
# - Never share your .env file or commit it to git
# - Update .gitignore to ensure .env is ignored
