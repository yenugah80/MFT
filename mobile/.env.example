# MyFoodTracker Mobile App Environment Variables
# Copy this file to .env and fill in your actual values

# Clerk Authentication
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key-here

# API Configuration
# IMPORTANT: Use EXPO_PUBLIC_API_BASE_URL (not EXPO_PUBLIC_API_URL)
# Default: https://myfoodtracker.onrender.com/api
EXPO_PUBLIC_API_BASE_URL=https://myfoodtracker.onrender.com/api

# To use local backend instead:
# EXPO_PUBLIC_API_BASE_URL=http://localhost:5001/api

# Analytics (optional)
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn-here
EXPO_PUBLIC_FIREBASE_CONFIG=your-firebase-config-json-here

# Feature Flags (optional)
EXPO_PUBLIC_ENABLE_ANALYTICS=true
EXPO_PUBLIC_ENABLE_CRASH_REPORTING=true

# IMPORTANT: Never commit the actual .env file to git!
# Expo public variables are safe to expose (they're bundled in the app)
# But keep non-public secrets on the backend only!
