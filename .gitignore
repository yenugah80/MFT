# Separate repos nested inside this directory
gesture-rush/

# Dependencies
node_modules/

# Environment
.env
.env.local
.env.*.local

# Google OAuth credential files (never commit these)
client_secret_*.json
*credentials*.json

# Expo
.expo/
dist/
web-build/

# Native (generated by Expo prebuild)
ios/
android/

# Build outputs
*.tsbuildinfo
build/
.cache/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# macOS
.DS_Store

# IDE
.idea/
*.swp
*.swo

# Local agent/browser state
.clawhub/
.playwright-mcp/
.claude/projects/
.claude/worktrees/
skills/

# Local QA screenshots
mobile/*preview*.png
mobile/root-*.png
mobile/reset-password*.png
mobile/sign-in-*.png
mobile/sign-up-*.png

# Credentials (never commit)
*.pem
*.p8
*.p12
*.key
*.jks
*.mobileprovision

# Firebase config — injected at build time via EAS Secrets
mobile/google-services.json
mobile/GoogleService-Info.plist
mobile/google-service-account.json

# Cloudflare
.wrangler/
.dev.vars
gesture-rush-clone/
