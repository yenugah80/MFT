{
    "claudeCode.useTerminal": true,
    "stylelint.validate": ["css", "scss", "less"],
    "css.validate": false,
    "scss.validate": false,
    "less.validate": false,
    "eslint.workingDirectories": [
        {
            "directory": "mobile",
            "changeProcessCWD": true
        },
        {
            "directory": "backend",
            "changeProcessCWD": true
        }
    ],
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    }
}
